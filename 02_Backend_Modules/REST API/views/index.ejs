<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>students data</title>
</head>
<body>
    <h1>students data</h1>
    <table border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Name</th>
                <th>age</th>
                <th>city</th>
            </tr>
        </thead>
        <tbody>
            <% students.forEach(student => { %>
                <tr>
                    <td><%= student.Name %></td>
                    <td><%= student.age %></td>
                    <td><%= student.city %></td>
                </tr>
            <% }) %>
        </tbody>

    
</body>
</html>